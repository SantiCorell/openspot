# App: pooler transaccional Supabase (6543) u otra URL. Codifica caracteres especiales en la contraseña (; → %3B).
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5432/openspot?schema=public"
# Migraciones (prisma.config): conexión que admita DDL. Supabase: pooler sesión :5432 o db.PROJECT.supabase.co:5432
DIRECT_URL=""
# TLS Postgres: en local (MITM/antivirus) o si Prisma en Vercel falla con "self-signed certificate in chain".
# DATABASE_SSL_REJECT_UNAUTHORIZED=false
# Con Supabase en Vercel, el código relaja verificación del certificado automáticamente salvo que fuerces:
# DATABASE_SSL_STRICT=true
NEXTAUTH_SECRET="genera-un-secreto-largo"
NEXTAUTH_URL="http://localhost:3000"
# Producción: misma URL canónica que uses en el navegador (evita fallos OAuth). Auth.js v5 también lee AUTH_URL.
# AUTH_URL="https://www.openspot.es"
# AUTH_SECRET="mismo valor que NEXTAUTH_SECRET"
# URL pública del sitio (sin barra final). Crítica para sitemap, robots, canonical y JSON-LD en producción.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
# Mapas en landing (opcional). Sin clave se usa OpenStreetMap; con clave, Google Maps.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=""
# Emails extra con acceso a /admin (separados por coma). El fundador también está incluido en código.
ADMIN_EMAILS=""
# Google Cloud → OAuth → Orígenes JS + redirect /api/auth/callback/google para cada host (www y sin www si ambos existen).
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
# IA — compatible OpenAI (DeepSeek)
DEEPSEEK_API_KEY=""
DEEPSEEK_BASE_URL="https://api.deepseek.com"
DEEPSEEK_MODEL="deepseek-chat"
# OpenStreetMap / Overpass (competencia por pin). Opcional: URL del endpoint Overpass.
OVERPASS_API_URL=""
# User-Agent para Nominatim (geocodificación). Recomendado en producción.
NOMINATIM_USER_AGENT=""
# Stripe (no subas sk_live a git). Rota la clave si se filtra.
STRIPE_SECRET_KEY=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
# Webhook: Dashboard → Webhooks → endpoint /api/webhooks/stripe (eventos checkout + subscription)
STRIPE_WEBHOOK_SECRET=""
# Tras `npm run stripe:seed` (idempotente) copia los price id:
STRIPE_PRICE_PRO_MONTHLY=""
STRIPE_PRICE_ENTERPRISE_MONTHLY=""
# Pago único: estudio/informe extra y comparación extra (tarifas por plan; ver lib/billing/plans.ts)
STRIPE_PRICE_EXTRA_SEARCH_FREE=""
STRIPE_PRICE_EXTRA_SEARCH_PRO=""
STRIPE_PRICE_EXTRA_SEARCH_ENTERPRISE=""
STRIPE_PRICE_EXTRA_COMPARISON_FREE=""
STRIPE_PRICE_EXTRA_COMPARISON_PRO=""
STRIPE_PRICE_EXTRA_COMPARISON_ENTERPRISE=""
